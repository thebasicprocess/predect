# Z.AI API (required)
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/

# Evidence API keys (optional — keyless sources work without these)
NEWS_API_KEY=
GNEWS_API_KEY=
ALPHA_VANTAGE_KEY=

# Frontend URL (used by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database path (defaults to ./predect.db)
DATABASE_URL=./predect.db

# CORS — comma-separated list of allowed origins (leave empty for dev)
# Example: https://predect.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=
